# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=tagta

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Token 过期时间（秒）
TOKEN_EXPIRE_SECONDS=1800

# 服务器配置
HOST=0.0.0.0
PORT=8080

# CORS 允许的来源（逗号分隔，生产环境请替换为实际域名）
ALLOWED_ORIGINS=*

# 京东OSS配置
JD_OSS_BUCKET=
JD_OSS_ENDPOINT=
JD_OSS_ACCESS_KEY=
JD_OSS_SECRET_KEY=
JD_OSS_PREFIX=

# Apple 登录配置
APPLE_CLIENT_ID=com.sirius.tagta